        "data/extracted/claims/reg_ggd_flevoland_ketenaanpak_gezond_gewicht_almere.json",
        "data/extracted/claims/mun_almere_lea_2024_2028.json",
        "data/extracted/claims/sentence_validator_rejects.json",
        "data/extracted/claims/dedup_log.json"
      ]
    },
    {
      "stage_id": "phase6_current_interpretation",
      "kind": "script",
      "description": "Build the conflict register and current interpretation layer from the claim graph.",
      "script": "src/build_current_interpretation.py",
      "depends_on": [
        "phase4_claims_all_docs"
      ],
      "inputs": [
        "config/claim_resolution_rules.json",
        "src/build_current_interpretation.py"
      ],
      "outputs": [
        "data/extracted/claims/conflict_register.json",
        "data/extracted/claims/current_interpretation.json"
      ]
    },
    {
      "stage_id": "phase25_1_workagenda_operational_layer",
      "kind": "script",
      "description": "Build the operational D5 workagenda target layer from workagenda, format, process, and finance claims.",
      "script": "src/build_workagenda_d5_operational_requirements.py",
      "depends_on": [
        "phase4_claims_all_docs",
        "phase1_document_inventory"
      ],
      "inputs": [
        "data/extracted/claims/claims_master.jsonl",
        "data/extracted/document_inventory.json",
        "src/build_workagenda_d5_operational_requirements.py"
      ],
      "outputs": [
        "data/extracted/workagenda_d5_operational_requirements.json"
      ]
    },
    {
      "stage_id": "phase25_2_local_source_strengthening_almere",
      "kind": "script",
      "description": "Build the Almere local source-strengthening layer with present sources, candidate primary sources, and remaining intake gaps.",
      "script": "src/build_local_source_strengthening_almere.py",
      "depends_on": [
        "phase1_document_inventory",
        "phase25_1_workagenda_operational_layer"
      ],
      "inputs": [
        "data/raw/manifest.json",
        "data/extracted/document_inventory.json",
        "data/extracted/workagenda_d5_operational_requirements.json",
        "src/build_local_source_strengthening_almere.py"
      ],
      "outputs": [
        "data/extracted/local_source_strengthening_almere.json"
      ]
    },
    {
      "stage_id": "phase25_3_workagenda_nulmeting_capacity",
      "kind": "script",
      "description": "Build the public-source nulmeting and capacity prefill layer for each D5 workagenda target, with local validation gaps kept explicit.",
      "script": "src/build_workagenda_nulmeting_capacity.py",
      "depends_on": [
        "phase25_1_workagenda_operational_layer",
        "phase25_2_local_source_strengthening_almere"
      ],
      "inputs": [
        "data/extracted/workagenda_d5_operational_requirements.json",
        "data/extracted/local_source_strengthening_almere.json",
        "data/intermediate/source_markdown/reg_ggd_flevoland_2024_volwassenen_gemeenten.md",
        "data/intermediate/source_markdown/reg_ggd_flevoland_2024_ouderen_gemeenten.md",
        "src/build_workagenda_nulmeting_capacity.py"
      ],
      "outputs": [
        "data/extracted/workagenda_nulmeting_capacity.json"
      ]
    },
    {
      "stage_id": "phase25_4_d6_governance_collaboration",
      "kind": "script",
      "description": "Build the public-source D6 governance and collaboration role map, keeping local validation and decision fields explicit.",
      "script": "src/build_d6_governance_collaboration.py",
      "depends_on": [
        "phase4_claims_all_docs",
        "phase25_3_workagenda_nulmeting_capacity"
      ],
      "inputs": [
        "data/extracted/claims/claims_master.jsonl",
        "data/curated/regional_roles_and_splits_almere_flevoland.json",
        "data/extracted/workagenda_nulmeting_capacity.json",
        "src/build_d6_governance_collaboration.py"
      ],
      "outputs": [
        "data/extracted/d6_governance_collaboration.json"
      ]
    },
    {
      "stage_id": "phase25_4b_almere_d6_responsibility_register",
      "kind": "script",
      "description": "Build the Almere D6 responsibility register for public-source prefill, scale separation, funding status, and local validation fields.",
      "script": "src/build_almere_d6_responsibility_register.py",
      "depends_on": [
        "phase25_4_d6_governance_collaboration"
      ],
      "inputs": [
        "docs/phase25-sprint25.4-d6-almere-responsibility-pack-plan.md",
        "data/extracted/d6_governance_collaboration.json",
        "src/build_almere_d6_responsibility_register.py"
      ],
      "outputs": [
        "data/extracted/municipal/almere_d6_responsibility_register.json"
      ]
    },
    {
      "stage_id": "phase7_phase8_master_views",
      "kind": "script",
      "description": "Generate the D5/D6 master model plus the computed Almere view and decision shell.",
      "script": "src/build_master_views.py",
      "depends_on": [
        "phase6_current_interpretation",
        "phase25_1_workagenda_operational_layer"
      ],
      "inputs": [
        "data/extracted/workagenda_d5_operational_requirements.json",
        "src/build_master_views.py"
      ],
      "outputs": [
        "data/extracted/claims/d5_d6_master.json",
        "data/extracted/municipal/almere_current_view.json"
      ]
    },
    {
      "stage_id": "phase8_local_decision_shell",
      "kind": "asset",
      "description": "Reserve the non-overwritable Almere local decision file for human-entered choices.",
      "depends_on": [],
      "outputs": [
        "data/extracted/municipal/almere_local_decisions.json"
      ]
    },
    {
      "stage_id": "phase9_prompt_assets",
      "kind": "asset",
      "description": "Reusable prompt templates for document extraction, claims, conflict resolution, and municipal views.",
      "depends_on": [],
      "outputs": [
        "prompts/extract_document.md",
        "prompts/extract_table.md",
        "prompts/extract_claims.md",
        "prompts/resolve_conflicts.md",
        "prompts/build_municipal_view.md"
      ]
    },
    {
      "stage_id": "phase10_pipeline_orchestration",
      "kind": "asset",
      "description": "Pipeline graph, runner, and tests for deterministic stage execution.",
      "depends_on": [],
      "outputs": [
        "config/pipeline_graph.json",
        "src/run_pipeline.py",
        "tests/test_pipeline_graph.py"
      ]
    },
    {
      "stage_id": "phase11_quality_control",
      "kind": "script",
      "description": "Validate extraction integrity, surface review-heavy items, and write the review queue plus QC report.",
      "script": "src/build_quality_control.py",
      "depends_on": [
        "phase7_phase8_master_views",
        "phase8_local_decision_shell",
        "phase25_4b_almere_d6_responsibility_register"
      ],
      "inputs": [
        "data/extracted/municipal/almere_d6_responsibility_register.json",
        "data/schemas/almere_d6_responsibility_register.schema.json",
        "src/build_quality_control.py",
        "src/build_current_interpretation.py"
      ],
      "outputs": [
        "data/extracted/qc_report.json",
        "data/extracted/review_queue.json"
      ]
    },
    {
      "stage_id": "phase12_site_view_models",
      "kind": "script",
      "description": "Build Dutch executive site view models from the claim layer, Almere view, and review guidance.",
      "script": "src/build_site_view_models.py",
      "depends_on": [
        "phase11_quality_control"
      ],
      "inputs": [
        "config/data_quality_perspectives.json",
        "config/site_taxonomy.json",
        "config/site_updates.json",
        "config/timeline_curation.json",
        "src/build_site_view_models.py"
      ],
      "outputs": [
        "data/site/site_home_view.json",
        "data/site/site_almere_view.json",
        "data/site/dashboard_view.json",
        "data/site/timeline_register.json",
        "data/site/site_timeline_view.json",
        "data/site/site_themes_view.json",
        "data/site/site_reference_view.json",
        "data/site/site_sources_view.json",
        "data/site/site_updates_view.json",
        "data/site/site_manifest.json",
        "data/site/decision_view_models",
        "data/site/action_view_models",
        "data/site/theme_view_models",
        "data/site/reference_topic_view_models",
        "data/site/source_view_models"
      ]
    },
    {
      "stage_id": "phase24_data_quality_audit",
      "kind": "script",
      "description": "Audit current claims and site-data against the six quality perspectives, broad rest buckets, and rough publication text risks.",
      "script": "src/build_data_quality_audit.py",
      "depends_on": [
        "phase12_site_view_models"
      ],
      "inputs": [
        "config/data_quality_perspectives.json",
        "data/extracted/claims/claims_master.jsonl",
        "data/extracted/claims/current_interpretation.json",
        "data/extracted/review_queue.json",
        "data/site",
        "src/build_data_quality_audit.py"
      ],
      "outputs": [
        "data/extracted/data_quality_audit.json"
      ]
    },
    {
      "stage_id": "phase13_site_render",
      "kind": "script",
      "description": "Render the static executive site, search index, and public assets for GitHub Pages deployment.",
      "script": "src/render_site.py",
      "depends_on": [
        "phase24_data_quality_audit"
      ],
      "inputs": [
        "assets/site.css",
        "assets/site.js",
        "src/render_site.py",
        "templates/base.html"
      ],
      "outputs": [
        "dist/index.html",
        "dist/almere/index.html",
        "dist/decisions/index.html",
        "dist/actions/index.html",
        "dist/dashboard/index.html",
        "dist/timeline/index.html",
        "dist/updates/index.html",
        "dist/themes/index.html",
        "dist/reference/index.html",
        "dist/reference/topics/index.html",
        "dist/sources/index.html",
        "dist/site-build.json",
        "dist/search-index.json",
        "dist/assets/site.css",
        "dist/assets/site.js"
      ]
    }
  ]
}
