        "data/extracted/claims/mun_almere_2024_2026_brede_spuk_gala_plan_van_aanpak.json",
        "data/extracted/claims/mun_almere_2024_2026_visie_gezondheidsbeleid_beleidstekst.json",
        "data/extracted/claims/mun_almere_2024_2026_visie_gezondheidsbeleid_besluitenlijst.json",
        "data/extracted/claims/mun_almere_2024_2026_visie_gezondheidsbeleid_raadsvoorstel_geamendeerd.json",
        "data/extracted/claims/mun_almere_2024_2034_maatschappelijke_agenda_beleidstekst.json",
        "data/extracted/claims/mun_almere_2024_2034_maatschappelijke_agenda_besluitenlijst.json",
        "data/extracted/claims/mun_almere_2024_2034_maatschappelijke_agenda_opzet_evaluatie.json",
        "data/extracted/claims/mun_almere_2024_2034_maatschappelijke_agenda_raadsvoorstel_geamendeerd.json",
        "data/extracted/claims/mun_almere_sociaal_domein_informatiepagina.json",
        "data/extracted/claims/mun_almere_sociale_staat_gateway.json",
        "data/extracted/claims/reg_ggd_flevoland_2024_ouderen_gemeenten.json",
        "data/extracted/claims/reg_ggd_flevoland_2024_volwassenen_gemeenten.json",
        "data/extracted/claims/reg_ggd_flevoland_valpreventie_almere.json",
        "data/extracted/claims/reg_zonmw_doorontwikkeling_zorgzaam_flevoland.json",
        "data/extracted/claims/mun_almere_2026_stevige_lokale_teams_raad.json",
        "data/extracted/claims/mun_almere_wijkteams.json",
        "data/extracted/claims/nat_vng_richtinggevend_kader_toegang_lokale_teams.json",
        "data/extracted/claims/nat_tsd_basisfuncties_lokale_teams.json",
        "data/extracted/claims/reg_ggd_flevoland_begroting_2026.json",
        "data/extracted/claims/reg_ggd_flevoland_kennis_en_advies.json",
        "data/extracted/claims/reg_ggd_flevoland_jgz_almere_profile.json",
        "data/extracted/claims/mun_almere_2026_stevige_lokale_teams_geamendeerd_raadsvoorstel.json",
        "data/extracted/claims/mun_almere_2026_stevige_lokale_teams_raadsvoorstel.json",
        "data/extracted/claims/mun_almere_2026_stevige_lokale_teams_begrotingswijziging.json",
        "data/extracted/claims/mun_almere_2026_stevige_lokale_teams_besluitenlijst.json",
        "data/extracted/claims/mun_almere_samenwerkingsprojecten.json",
