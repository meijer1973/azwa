        "data/extracted/claims/nat_azwa_2025_aanbiedingsbrief.json",
        "data/extracted/claims/nat_iza_2022_integraal_zorgakkoord.json",
        "data/extracted/claims/nat_gala_2023_gezond_en_actief_leven.json",
        "data/extracted/claims/mun_almere_pga_seo_businesscase_2024.json",
        "data/extracted/claims/reg_flevoland_2023_regiobeeld.json",
        "data/extracted/claims/nat_vng_azwa_faq_middelen.json",
        "data/extracted/claims/nat_vng_azwa_faq_uitvoeringscapaciteit.json",
