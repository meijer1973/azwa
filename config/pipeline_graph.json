{
  "version": 1,
  "default_target": "phase13_site_render",
  "stages": [
    {
      "stage_id": "phase0_setup",
      "kind": "script",
      "description": "Prepare the raw corpus layout and manifest from the selected source files.",
      "script": "src/phase0_setup.py",
      "depends_on": [],
      "inputs": [
        "sources",
        "src/phase0_setup.py"
      ],
      "outputs": [
        "data/raw/manifest.json"
      ]
    },
    {
      "stage_id": "phase1_document_inventory",
      "kind": "script",
      "description": "Build the normalized inventory and extraction priority view for all source documents.",
      "script": "src/build_document_inventory.py",
      "depends_on": [
        "phase0_setup"
      ],
      "inputs": [
        "data/raw/manifest.json",
        "src/build_document_inventory.py"
      ],
      "outputs": [
        "data/extracted/document_inventory.json"
      ]
    },
    {
      "stage_id": "phase2_structural_extractions",
      "kind": "script",
      "description": "Extract text, chunks, and table candidates from the curated Markdown and raw corpus.",
      "script": "src/build_structural_extractions.py",
      "depends_on": [
        "phase0_setup",
        "phase1_document_inventory"
      ],
      "inputs": [
        "data/raw/manifest.json",
        "data/raw/national",
        "data/raw/regional",
        "data/raw/municipal",
        "data/intermediate/source_markdown",
        "sources markdown canonical",
        "sources markdown",
        "sources markdown context",
        "src/build_structural_extractions.py"
      ],
      "outputs": [
        "data/intermediate/text",
        "data/intermediate/chunks",
        "data/intermediate/tables"
      ]
    },
    {
      "stage_id": "phase3_document_extractions_all_docs",
      "kind": "script",
      "description": "Generate immutable document extraction JSON for the full manifest corpus.",
      "script": "src/build_document_extractions.py",
      "depends_on": [
        "phase1_document_inventory",
        "phase2_structural_extractions"
      ],
      "inputs": [
        "src/build_document_extractions.py"
      ],
      "outputs": [
        "data/extracted/documents/nat_azwa_2025_definitief.json",
        "data/extracted/documents/nat_azwa_2025_onderhandelaarsakkoord.json",
        "data/extracted/documents/nat_azwa_2026_cw31_kader_d5_d6.json",
