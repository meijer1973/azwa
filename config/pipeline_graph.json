        "data/extracted/documents/mun_almere_lea_2024_2028.json"
      ]
    },
    {
      "stage_id": "phase4_claims_all_docs",
      "kind": "script",
      "description": "Convert the full document extraction set into append-only claims with explicit seed relations where available.",
      "script": "src/build_claims_top5.py",
      "depends_on": [
        "phase3_document_extractions_all_docs"
      ],
      "inputs": [
        "config/authority_rules.json",
        "data/schemas/claim.schema.json",
        "src/build_claims_top5.py"
      ],
      "outputs": [
        "data/extracted/claims/claims_master.jsonl",
        "data/extracted/claims/nat_azwa_2025_definitief.json",
        "data/extracted/claims/nat_azwa_2025_onderhandelaarsakkoord.json",
        "data/extracted/claims/nat_azwa_2026_cw31_kader_d5_d6.json",
