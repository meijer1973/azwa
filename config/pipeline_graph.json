        "data/extracted/documents/mun_almere_2024_2026_visie_gezondheidsbeleid_beleidstekst.json",
        "data/extracted/documents/mun_almere_2024_2026_visie_gezondheidsbeleid_besluitenlijst.json",
        "data/extracted/documents/mun_almere_2024_2026_visie_gezondheidsbeleid_raadsvoorstel_geamendeerd.json",
