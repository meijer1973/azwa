{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/meijer1973/azwa/blob/main/data/schemas/claim.schema.json",
  "title": "AZWA Claim",
  "type": "object",
  "required": [
    "claim_id",
    "topic",
    "subtopic",
    "claim_type",
    "normative_status",
    "time_status",
    "statement",
    "source_document_id",
    "source_location",
    "publisher",
    "jurisdiction_level",
    "document_status",
    "authority_weight",
    "publication_date",
    "effective_from",
    "effective_to",
    "validity_status",
    "applies_to",
    "confidence",
    "human_review_status",
    "relations"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "subtopic": {
      "type": "string"
    },
    "claim_type": {
      "type": "string"
    },
    "normative_status": {
      "type": "object",
      "required": [
        "status",
        "label",
        "source_authority",
        "has_normative_language",
        "public_wording_guardrail",
        "needs_attribution"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "binding",
            "agreement",
            "expectation",
            "guidance",
            "lower_authority_signal",
            "contextual"
          ]
        },
        "label": {
          "type": "string"
        },
        "source_authority": {
          "type": "string"
        },
        "has_normative_language": {
          "type": "boolean"
        },
        "public_wording_guardrail": {
          "type": "string"
        },
        "needs_attribution": {
          "type": "boolean"
        }
      }
    },
    "time_status": {
      "type": "object",
      "required": [
        "status",
        "label",
        "date_signal",
        "source_temporal_anchor",
        "public_wording_guardrail",
        "needs_review"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "formal_deadline",
            "expected_moment",
            "review_or_update_moment",
            "budget_calendar_moment",
            "implementation_horizon",
            "local_planning_context",
            "source_dated_moment",
            "publication_or_context_date",
            "undated_context"
          ]
        },
        "label": {
          "type": "string"
        },
        "date_signal": {
          "type": "string",
          "enum": [
            "exact_date",
            "quarter",
            "period",
            "year",
            "month_or_cycle",
            "none"
          ]
        },
        "source_temporal_anchor": {
          "type": "string",
          "enum": [
            "explicit_text_signal",
            "publication_context"
          ]
        },
        "public_wording_guardrail": {
          "type": "string"
        },
        "needs_review": {
          "type": "boolean"
        }
      }
    },
    "statement": {
      "type": "string"
    },
    "source_document_id": {
      "type": "string"
    },
    "source_location": {
      "type": "object",
      "required": [
        "source_statement_ids",
        "pages",
        "sections",
        "evidence_quotes"
      ],
      "properties": {
        "source_statement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pages": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_quotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "publisher": {
      "type": "string"
    },
    "instrument_type": {
      "type": "string"
    },
    "jurisdiction_level": {
      "type": "string"
    },
    "document_status": {
      "type": "string"
    },
    "authority_weight": {
      "type": "number"
    },
    "publication_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "effective_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "effective_to": {
      "type": [
        "string",
        "null"
      ]
    },
    "validity_status": {
      "type": "string"
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "human_review_status": {
      "type": "string"
    },
    "source_statement_type": {
      "type": "string"
    },
    "claim_extraction_run_id": {
      "type": "string"
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "target_claim_id"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "repeats",
              "clarifies",
              "narrows",
              "broadens",
              "supersedes",
              "partially_supersedes",
              "conflicts_with",
              "implements",
              "derives_from",
              "depends_on",
              "expires",
              "postpones",
              "transfers_responsibility_to"
            ]
          },
          "target_claim_id": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
